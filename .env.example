# ====================================================
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ для сайта "Yuki Shop"
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
# ====================================================

# --- Gmail настройки для отправки кодов ---
# Как получить App Password:
# 1. https://myaccount.google.com/security
# 2. Включите двухфакторную аутентификацию
# 3. "Пароли приложений" → создайте для "Почта"
# 4. Скопируйте 16-значный пароль

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# --- Сервер ---
# Порт (по умолчанию 3001)
PORT=3001

# Режим работы (production или development)
NODE_ENV=production
