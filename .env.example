# Gmail настройки для отправки кодов подтверждения
# 
# Как получить App Password для Gmail:
# 1. Зайдите в https://myaccount.google.com/security
# 2. Включите двухфакторную аутентификацию (2FA)
# 3. Перейдите в раздел "Пароли приложений" (App Passwords)
# 4. Создайте пароль для приложения "Почта" и устройства "Другое"
# 5. Скопируйте 16-значный пароль и вставьте ниже

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
